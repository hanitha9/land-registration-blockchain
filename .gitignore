# Dependencies
node_modules/
*/node_modules/

# Environment files (contains secrets)
.env
.env.local
.env.production
backend/.env
frontend/.env

# Uploads (user uploaded files - too large)
backend/uploads/*
!backend/uploads/.gitkeep

# Wallet (Fabric identities - sensitive)
backend/wallet/

# Logs
*.log
npm-debug.log*

# Build files
frontend/build/
dist/

# OS files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

